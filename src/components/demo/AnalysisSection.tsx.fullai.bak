import { useMemo } from "react";

type AnalysisSectionProps = {
  analysis?: {
    MAX_DELTA?: number | string;
    Trigger?: string;
    AK_Primary?: string;
    APCE_Miss?: string;
  };
  delta: string;
  eLevel: string;
  text: string;
  judgment: string;
  contextText: string;
  onNext: () => void;
};

type SignalType =
  | "FEAR"
  | "ANXIETY"
  | "DISSAT"
  | "SAFE"
  | "TRUST"
  | "DISCOMFORT";

type AlignmentKeyType =
  | "AK_SAFE"
  | "AK_PREDICT"
  | "AK_TRUST"
  | "AK_RESPECT"
  | "AK_ROLE";

type ApceType = "A" | "P" | "C" | "E";
type RType = "R+" | "R-";
type TriggerType = "Triggerあり" | "Triggerなし";

function normalizeText(text: string) {
  return (text || "").toLowerCase().trim();
}

function detectSignal(text: string): SignalType {
  const normalized = normalizeText(text);
  if (!normalized) return "DISCOMFORT";

  const hasAny = (keywords: string[]) =>
    keywords.some((keyword) => normalized.includes(keyword));

  const fearKeywords = [
    "怖",
    "恐",
    "危険",
    "危ない",
    "こわい",
    "命",
    "息ができ",
    "苦しい",
    "強い痛み",
  ];

  const anxietyKeywords = [
    "不安",
    "心配",
    "落ち着か",
    "見通し",
    "どうなる",
    "先が見え",
    "予定がわから",
    "まだ呼ばれ",
    "何度も確認",
    "繰り返し確認",
    "待たされ",
    "説明が伝わ",
    "説明不足",
    "表情が硬",
    "届かない",
    "置かれた感覚",
  ];

  const dissatKeywords = [
    "怒",
    "不満",
    "納得でき",
    "冷たい",
    "雑",
    "ひどい",
    "ちゃんとして",
    "説明が違う",
    "対応が悪い",
    "押し返す",
    "距離",
    "冷え",
    "悲しみ",
    "受け止められていない",
    "諦め",
  ];

  const safeKeywords = ["安心", "大丈夫", "落ち着い", "ほっと", "安堵"];
  const trustKeywords = [
    "信頼",
    "任せ",
    "ありがたい",
    "感謝",
    "納得した",
    "安心して任せ",
  ];

  if (hasAny(fearKeywords)) return "FEAR";
  if (hasAny(anxietyKeywords)) return "ANXIETY";
  if (hasAny(dissatKeywords)) return "DISSAT";
  if (hasAny(safeKeywords)) return "SAFE";
  if (hasAny(trustKeywords)) return "TRUST";

  return "DISCOMFORT";
}

function detectAlignmentKey(signal: SignalType): AlignmentKeyType {
  if (signal === "FEAR") return "AK_SAFE";
  if (signal === "ANXIETY") return "AK_PREDICT";
  if (signal === "DISSAT") return "AK_RESPECT";
  if (signal === "TRUST") return "AK_TRUST";
  if (signal === "SAFE") return "AK_TRUST";
  return "AK_PREDICT";
}

function getSignalLabel(signal: SignalType) {
  const map: Record<SignalType, string> = {
    FEAR: "恐れ",
    ANXIETY: "不安",
    DISSAT: "不満・反発",
    SAFE: "安心",
    TRUST: "信頼",
    DISCOMFORT: "違和感",
  };
  return map[signal];
}

function getSignalCopy(signal: SignalType) {
  switch (signal) {
    case "FEAR":
      return "今は、怖さや危なさが強く意識されている状態です。";
    case "ANXIETY":
      return "今は、この先どうなるのかが見えにくく、気持ちが落ち着きにくい状態です。";
    case "DISSAT":
      return "今は、不満や反発が表に出ており、相手との間に距離が生まれています。";
    case "SAFE":
      return "今は、安心して状況を受け止められている状態です。";
    case "TRUST":
      return "今は、この相手に任せても大丈夫だと思える状態です。";
    default:
      return "まだ大きな問題にはなっていませんが、何かが噛み合っていない感じが残っています。";
  }
}

function getAlignmentLabel(key: AlignmentKeyType) {
  switch (key) {
    case "AK_SAFE":
      return "安心";
    case "AK_PREDICT":
      return "見通し";
    case "AK_TRUST":
      return "信頼";
    case "AK_RESPECT":
      return "尊重";
    case "AK_ROLE":
      return "役割理解";
    default:
      return key;
  }
}

function getAlignmentCopy(key: AlignmentKeyType) {
  switch (key) {
    case "AK_SAFE":
      return "今は、ここにいて大丈夫だと思える感じが弱くなっています。";
    case "AK_PREDICT":
      return "今は、何が起きていて、この先どうなるのかがつかみにくくなっています。";
    case "AK_TRUST":
      return "今は、この相手に話しても大丈夫だと思える感じが弱くなっています。";
    case "AK_RESPECT":
      return "今は、自分の気持ちをきちんと受け止めてもらえていない感じが強くなっています。";
    case "AK_ROLE":
      return "今は、誰が何をしてくれるのかが分かりにくくなっています。";
    default:
      return "この場面では、ここがいちばん足りなくなっています。";
  }
}

function detectApce(key: AlignmentKeyType): ApceType {
  if (key === "AK_SAFE") return "A";
  if (key === "AK_PREDICT") return "C";
  if (key === "AK_RESPECT") return "A";
  if (key === "AK_TRUST") return "A";
  if (key === "AK_ROLE") return "C";
  return "C";
}

function getApceLabel(apce: ApceType) {
  switch (apce) {
    case "A":
      return "共感";
    case "P":
      return "許容・制御";
    case "C":
      return "説明・予測";
    case "E":
      return "実行・環境";
    default:
      return apce;
  }
}

function getApceCopy(apce: ApceType) {
  switch (apce) {
    case "A":
      return "この場面では、まず気持ちを受け止める関わりが必要です。";
    case "P":
      return "この場面では、行動や場の流れを整える関わりが必要です。";
    case "C":
      return "この場面では、何が起きていて、この先どうなるかを言葉でつなぐ必要があります。";
    case "E":
      return "この場面では、実際の対応や周囲の環境を整えることが必要です。";
    default:
      return "この場面では、この関わり方が必要です。";
  }
}

function detectR(key: AlignmentKeyType, apce: ApceType): RType {
  if (
    (key === "AK_SAFE" && apce === "A") ||
    (key === "AK_PREDICT" && apce === "C") ||
    (key === "AK_RESPECT" && apce === "A") ||
    (key === "AK_TRUST" && apce === "A") ||
    (key === "AK_ROLE" && apce === "C")
  ) {
    return "R+";
  }
  return "R-";
}

function getRCopy(r: RType) {
  if (r === "R+") {
    return "いま必要な関わりと、現在の対応の向きはだいたい合っています。";
  }
  return "いま必要な関わりと、現在の対応の向きに少しズレがあります。";
}

function detectTrigger(
  delta: string,
  r: RType,
  signal: SignalType
): TriggerType {
  if ((delta === "3" || delta === "4") && r === "R-" && signal !== "SAFE") {
    return "Triggerあり";
  }
  return "Triggerなし";
}

function getTriggerCopy(trigger: TriggerType) {
  if (trigger === "Triggerあり") {
    return "このまま進むと、やり取りがさらにこじれやすい状態です。";
  }
  return "まだ大きく崩れる段階ではありません。";
}

function getDeltaMeta(delta: string) {
  switch (delta) {
    case "1":
      return {
        label: "Δ1",
        title: "まだ大きく表面化していない",
        copy: "まだ大きくは崩れていませんが、このままだとズレが残る段階です。",
        width: "25%",
      };
    case "2":
      return {
        label: "Δ2",
        title: "小さなズレが続いている",
        copy: "いまは小さなズレの段階ですが、放っておくと広がりやすい状態です。",
        width: "50%",
      };
    case "3":
      return {
        label: "Δ3",
        title: "緊張が高まり始めている",
        copy: "ズレが続いていて、関係の緊張がはっきり見え始めています。",
        width: "75%",
      };
    default:
      return {
        label: "Δ4",
        title: "強い緊張状態",
        copy: "関係の緊張がかなり高く、このままだと大きく崩れやすい状態です。",
        width: "100%",
      };
  }
}

function getPhaseCopy(eLevel: string) {
  if (eLevel === "e1") {
    return "今は、この状態として見ておく段階です。";
  }
  if (eLevel === "e2") {
    return "今は、この状態として対処が必要な段階です。";
  }
  if (eLevel === "e3") {
    return "今は、この状態をそのままにせず、関係を立て直していく段階です。";
  }
  return "今は、この状態として捉えながら対処していく段階です。";
}

export default function AnalysisSection({
  analysis,
  delta,
  eLevel,
  text,
  judgment,
  contextText,
  onNext,
}: AnalysisSectionProps) {
  const finalContextBase = useMemo(() => {
    return contextText && contextText.trim().length > 0 ? contextText : text;
  }, [contextText, text]);

  const signal = detectSignal(finalContextBase);
  const alignmentKey = detectAlignmentKey(signal);
  const apce = detectApce(alignmentKey);
  const rValue = detectR(alignmentKey, apce);
  const trigger = detectTrigger(delta, rValue, signal);
  const deltaMeta = getDeltaMeta(delta);

  const triggerTone =
    trigger === "Triggerあり"
      ? {
          card: "border-rose-300 bg-rose-50",
          chip: "border-rose-300 bg-white text-rose-700",
          text: "text-rose-700",
        }
      : {
          card: "border-emerald-300 bg-emerald-50",
          chip: "border-emerald-300 bg-white text-emerald-700",
          text: "text-emerald-700",
        };

  const sectionShell =
    "overflow-hidden rounded-[22px] border border-stone-200 bg-[#fbfaf7] shadow-[0_12px_36px_rgba(15,23,42,0.05)]";

  const sectionHeader =
    "border-b border-stone-200 bg-[linear-gradient(180deg,#ede8dd_0%,#e6e1d6_100%)] px-6 py-7 sm:px-8";

  const sectionTitleClass =
    "mt-3 text-[34px] font-semibold tracking-[-0.02em] text-slate-900";

  const leadClass =
    "mt-4 max-w-4xl text-[18px] leading-9 text-stone-700";

  const groupWrap =
    "rounded-[18px] border border-stone-200 bg-white p-6 shadow-[0_3px_14px_rgba(15,23,42,0.04)]";

  const subCard =
    "rounded-[16px] border border-stone-200 bg-[#fcfbf8] p-5";

  const contextCard =
    "rounded-[18px] border-2 border-stone-300 bg-white p-6 shadow-[0_8px_22px_rgba(15,23,42,0.05)]";

  const primaryButton =
    "w-full rounded-[14px] bg-blue-600 py-4 text-[16px] font-medium text-white transition hover:bg-blue-700";

  const nextStepNote =
    "mt-5 rounded-[14px] border border-dashed border-stone-300 bg-white/80 px-4 py-3 text-[14px] leading-7 text-stone-600";

  const groupTitle = "mt-2 text-[24px] font-semibold text-slate-900";
  const groupLead = "mt-3 text-[17px] leading-8 text-stone-700";
  const bodyText = "mt-3 text-[15px] leading-8 text-stone-700";

  return (
    <section className={sectionShell}>
      <div className={sectionHeader}>
        <p className="text-[11px] uppercase tracking-[0.24em] text-stone-500">
          Step 02 / Analysis
        </p>
        <h2 className={sectionTitleClass}>関係の読み取り</h2>
        <p className={leadClass}>
          Final Contextをもとに、いま何が起きていて、どこにズレがあるかを見ます。
        </p>
      </div>

      {analysis && (
        <div className="mx-6 mt-6 rounded-[16px] border border-sky-200 bg-sky-50 px-5 py-4 text-[14px] text-slate-800 sm:mx-8">
          <p className="text-[11px] uppercase tracking-[0.18em] text-sky-700">
            AI Analysis / Step2
          </p>
          <div className="mt-2 grid gap-2 sm:grid-cols-2">
            <div>Δ：{String(analysis.MAX_DELTA ?? "")}</div>
            <div>Trigger：{String(analysis.Trigger ?? "")}</div>
            <div>AK：{String(analysis.AK_Primary ?? "")}</div>
            <div>Miss：{String(analysis.APCE_Miss ?? "")}</div>
          </div>
        </div>
      )}

      <div className="space-y-8 p-6 sm:p-8">
        <div className={contextCard}>
          <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
            01 / Final Context
          </p>
          <p className="mt-2 text-[24px] font-semibold tracking-[-0.01em] text-slate-900">
            整理された状況
          </p>
          <p className="mt-5 text-[21px] leading-10 text-stone-800">
            {finalContextBase}
          </p>
          <div className={nextStepNote}>
            次の一手：まず、いま表に出ている状態と、その強さを見ます。
          </div>
        </div>

        <div className={groupWrap}>
          <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
            02 / State Reading
          </p>
          <p className={groupTitle}>いま何が起きているか</p>
          <p className={groupLead}>
            ここでは、「どんな状態が出ているか」と「どのくらい強いか」を分けて見ます。
          </p>

          <div className="mt-6 grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
            <div className={subCard}>
              <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
                Signal
              </p>
              <p className="mt-2 text-[22px] font-semibold text-slate-900">
                {analysis ? analysis.AK_Primary : getSignalLabel(signal)}
              </p>
              <p className={bodyText}>{getSignalCopy(signal)}</p>
            </div>

            <div className={subCard}>
              <div className="flex items-center justify-between gap-3">
                <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
                  Δ（関係緊張）
                </p>
                <span className="rounded-full border border-stone-300 bg-white px-3 py-1 text-[12px] font-medium text-stone-700">
                  {deltaMeta.label}
                </span>
              </div>

              <p className="mt-2 text-[22px] font-semibold text-slate-900">
                {analysis ? 'Δ' + analysis.MAX_DELTA : deltaMeta.title}
              </p>

              <div className="mt-4 h-2.5 w-full overflow-hidden rounded-full bg-stone-200">
                <div
                  className="h-full rounded-full bg-slate-700"
                  style={{ width: deltaMeta.width }}
                />
              </div>

              <p className={bodyText}>{deltaMeta.copy}</p>
            </div>
          </div>

          <div className={nextStepNote}>
            次の一手：次に、何が足りていないかと、今の関わりがそこに合っているかを見ます。
          </div>
        </div>

        <div className={groupWrap}>
          <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
            03 / Missing Need
          </p>
          <p className={groupTitle}>何が不足しているか</p>
          <p className={groupLead}>
            必要なもの、求められる関わり、その適合を一つの流れで見ます。
          </p>

          <div className="mt-6 grid gap-4 lg:grid-cols-3">
            <div className={subCard}>
              <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
                AK
              </p>
              <p className="mt-2 text-[22px] font-semibold text-slate-900">
                {analysis ? analysis.AK_Primary : getAlignmentLabel(alignmentKey)}
              </p>
              <p className={bodyText}>{getAlignmentCopy(alignmentKey)}</p>
            </div>

            <div className={subCard}>
              <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
                APCE
              </p>
              <p className="mt-2 text-[22px] font-semibold text-slate-900">
                {analysis ? analysis.APCE_Miss : getApceLabel(apce)}
              </p>
              <p className={bodyText}>{getApceCopy(apce)}</p>
            </div>

            <div className={subCard}>
              <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
                R
              </p>
              <p className="mt-2 text-[22px] font-semibold text-slate-900">
                {analysis ? (analysis.Trigger === 'Yes' ? 'R-' : 'R+') : rValue}
              </p>
              <p className={bodyText}>{getRCopy(rValue)}</p>
            </div>
          </div>

          <div className={nextStepNote}>
            次の一手：最後に、このまま進むとどうなるかをまとめて見ます。
          </div>
        </div>

        <div className={groupWrap}>
          <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
            04 / Overall Reading
          </p>
          <p className={groupTitle}>このまま行くとどうなるか</p>
          <p className={groupLead}>
            最後に、崩れやすさ・段階・見立てをまとめます。
          </p>

          <div className="mt-6 grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
            <div className={`rounded-[16px] border p-5 ${triggerTone.card}`}>
              <div className="flex flex-wrap items-center justify-between gap-3">
                <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
                  Trigger
                </p>
                <span
                  className={`rounded-full border px-3 py-1 text-[12px] font-medium ${triggerTone.chip}`}
                >
                  {analysis ? analysis.Trigger : trigger}
                </span>
              </div>

              <p className={`mt-3 text-[23px] font-semibold ${triggerTone.text}`}>
                {trigger}
              </p>
              <p className={bodyText}>{getTriggerCopy(trigger)}</p>
            </div>

            <div className={subCard}>
              <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
                Phase
              </p>
              <p className="mt-2 text-[22px] font-semibold text-slate-900">
                {eLevel}
              </p>
              <p className={bodyText}>{getPhaseCopy(eLevel)}</p>
            </div>
          </div>

          <div className="mt-5">
            <div className={subCard}>
              <p className="text-[12px] uppercase tracking-[0.18em] text-stone-500">
                Insight
              </p>
              <p className="mt-3 text-[16px] leading-8 text-stone-700">
                {judgment}
              </p>
            </div>
          </div>

          <div className={nextStepNote}>
            次の一手：内容が確認できたら、「次の対応へ」で Step3 に進みます。
          </div>
        </div>

        <div className="rounded-[16px] border-t border-stone-200 pt-4">
          <div className="mt-4">
            <button onClick={onNext} className={primaryButton} type="button">
              次の対応へ
            </button>
          </div>
        </div>
      </div>
    </section>
  );
}